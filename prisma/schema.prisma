generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String
  grade        String
  classNumber  String
  phone        String
  studentCount String
  youtubeLink  String
  createdAt    DateTime @default(now())
}
